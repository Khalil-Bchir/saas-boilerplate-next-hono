# ==============================================================================
# BACKEND CONFIGURATION (.env.example)
# Scope: apps/api & Database Migrations
# ==============================================================================
# This file contains secrets and server-side config. 
# Do NOT use these in client-side code unless prefixed for Next.js.
# ------------------------------------------------------------------------------

# --- SERVER CORE ---
NODE_ENV=development
PORT=3000

# Service Communication (No trailing slashes)
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- DATABASE (Prisma) ---
# Primary connection (Transaction pooling)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
# Migration connection (Direct access)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# --- SUPABASE (Auth & Storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key # SERVER ONLY

# Auth Flow Redirects
SUPABASE_EMAIL_REDIRECT_URL=http://localhost:3001/auth/verify
SUPABASE_RESET_REDIRECT_URL=http://localhost:3001/auth/reset-password
SUPABASE_OAUTH_REDIRECT_URL=http://localhost:3001/auth/callback

# --- SECURITY & API GUARDRAILS ---
JWT_SECRET=replace_with_secure_random_string
COOKIE_SECRET=replace_with_secure_random_string
CRON_SECRET=replace_with_secure_random_string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- BUILD CONFIG ---
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
PRISMA_ENGINES_MIRROR=https://registry.npmmirror.com/-/binary/prisma